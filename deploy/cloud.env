# Configurazione Sheltr Cloud MQTT (modificata da Sheltr /config)
CLOUD_MQTT_ENABLED=0
CLOUD_MQTT_HOST=""
CLOUD_MQTT_PORT=1883
CLOUD_MQTT_USERNAME=""
CLOUD_MQTT_PASSWORD=""
CLOUD_MQTT_INSTANCE_ID="sheltr-mini"
CLOUD_MQTT_INSTANCE_NAME="Controllo Casa"
CLOUD_MQTT_CLIENT_ID="sheltr-cloud"
CLOUD_MQTT_BASE_TOPIC="dr154"
CLOUD_MQTT_KEEPALIVE=60
CLOUD_MQTT_POLL_INTERVAL=30
CLOUD_MQTT_QOS=0
CLOUD_MQTT_RETAIN=1
CLOUD_MQTT_BRIDGE_NAME="Sheltr Cloud"
CLOUD_MQTT_DISCOVERY_ENABLED=0
CLOUD_MQTT_CONFIG_TOPIC="dr154/sheltr-mini/config"
CLOUD_MQTT_COMMAND_TOPIC="dr154/sheltr-mini/cmd/light"
CLOUD_MQTT_RESPONSE_TOPIC="dr154/sheltr-mini/pub/light"
CLOUD_MQTT_PAYLOAD_FORMAT="frame_hex_space_crlf"
SHELTR_HTTP_BASE="http://127.0.0.1"
